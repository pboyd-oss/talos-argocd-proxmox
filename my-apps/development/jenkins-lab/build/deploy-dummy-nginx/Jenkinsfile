pipeline {
    agent {
        kubernetes {
            inheritFrom 'skaffold'
        }
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                container('kaniko') {
                    sh '''
                        /kaniko/executor \
                          --context=my-apps/development/jenkins-lab/build/deploy-dummy-nginx \
                          --dockerfile=my-apps/development/jenkins-lab/build/deploy-dummy-nginx/Dockerfile \
                          --destination=REGISTRY_PLACEHOLDER/dummy-nginx:${BUILD_NUMBER} \
                          --destination=REGISTRY_PLACEHOLDER/dummy-nginx:latest
                    '''
                }
            }
        }
        stage('Deploy') {
            steps {
                container('skaffold') {
                    sh 'cd my-apps/development/jenkins-lab/build/deploy-dummy-nginx && skaffold run --prune'
                }
            }
        }
    }
}
