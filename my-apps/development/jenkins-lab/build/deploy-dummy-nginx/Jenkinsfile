pipeline {
    agent {
        kubernetes {
            inheritFrom 'skaffold'
        }
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Deploy') {
            steps {
                container('skaffold') {
                    sh 'cd my-apps/development/jenkins-lab/build/deploy-dummy-nginx && skaffold run --prune'
                }
            }
        }
    }
}
