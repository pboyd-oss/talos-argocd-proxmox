{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  prHourlyLimit: 3,
  enabledManagers: [
    'helm-values',
    'kubernetes',
    'kustomize',
    'argocd',
    'terraform',
    'dockerfile',
    'custom.regex',
  ],
  argocd: {
    managerFilePatterns: [
      '/^infra/.+\\.yaml$/',
      '/^infrastructure/.+\\.yaml$/',
      '/^apps/.+\\.yaml$/',
      '/^my-apps/.+\\.yaml$/',
      '/^monitoring/.+\\.yaml$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/^infra/.+\\.yaml$/',
      '/^infrastructure/.+\\.yaml$/',
      '/^apps/.+\\.yaml$/',
      '/^my-apps/.+\\.yaml$/',
      '/^monitoring/.+\\.yaml$/',
      '/^iac/.+\\.yaml$/',
    ],
  },
  'helm-values': {
    managerFilePatterns: [
      '/^infra/.+/values\\.yaml$/',
      '/^apps/.+/values\\.yaml$/',
      '/^monitoring/.+/values\\.yaml$/',
      '/^my-apps/.+/values\\.yaml$/',
    ],
  },
  kustomize: {
    managerFilePatterns: [
      '(^|/)kustomization\\.ya?ml$',
    ],
  },
  terraform: {
    managerFilePatterns: [
      '//^iac/terraform/.+\\.tf$//',
    ],
  },
  dockerfile: {
    managerFilePatterns: [
      '//^docker/.+/Dockerfile$//',
    ],
  },
  packageRules: [
    {
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      matchManagers: [
        'helm-values',
        'kubernetes',
        'kustomize',
        'argocd',
      ],
      automerge: true,
      automergeType: 'branch',
    },
    {
      matchUpdateTypes: [
        'major',
      ],
      matchManagers: [
        'helm-values',
        'kubernetes',
        'kustomize',
        'argocd',
      ],
      automerge: false,
      prCreation: 'immediate',
    },
    {
      description: 'Enable container digest updates',
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'digest',
      ],
      enabled: true,
    },
    {
      description: 'Handle llama.cpp upstream versioning (CUDA 12 build)',
      matchPackageNames: [
        'ghcr.io/ggml-org/llama.cpp',
      ],
      versioning: 'regex:^server-cuda12-b(?<major>\\d+)$',
    },
    {
      description: 'Ignore NVIDIA CUDA updates (breaking changes)',
      enabled: false,
      matchPackageNames: [
        '/^nvidia/cuda/',
      ],
    },
    {
      description: 'Ignore Meilisearch updates (breaking changes)',
      enabled: false,
      matchPackageNames: [
        '/^getmeili/meilisearch/',
      ],
    },
    {
      description: 'SearXNG uses date-based tags (YYYY.M.DD-hash)',
      matchPackageNames: [
        'ghcr.io/searxng/searxng',
      ],
      versioning: 'regex:^(?<major>\\d{4})\\.(?<minor>\\d{1,2})\\.(?<patch>\\d{1,2})-[a-f0-9]+$',
    },
    {
      description: 'PostHog app images: group sidecar digest updates into one PR (Rust services can stay current)',
      matchPackageNames: [
        'posthog/posthog-node',
        'ghcr.io/posthog/posthog/capture',
        'ghcr.io/posthog/posthog/property-defs-rs',
        'ghcr.io/posthog/posthog/feature-flags',
        'ghcr.io/posthog/posthog/livestream',
        'ghcr.io/posthog/posthog/cyclotron-janitor',
        'ghcr.io/posthog/posthog/cymbal',
      ],
      matchFileNames: ['my-apps/development/posthog/**'],
      groupName: 'posthog images',
      automerge: true,
      automergeType: 'branch',
      schedule: ['every weekend'],
    },
    {
      description: 'PostHog MONOLITH (posthog/posthog): do NOT auto-bump. Requires ClickHouse-side config changes per release (named collections, satellite clusters, etc.) that our self-hosted config drifts from. 2026-04-19: the `9b518de` auto-merge broke migrate_clickhouse for a full day because upstream 0227_warpstream migration required a `warpstream_calculated_events` named collection our CH config lacked. Manually bump after checking PostHog/posthog/docker/clickhouse/config.d/default.xml for any new named_collections / remote_servers / storage_policies our config.d/default.xml is missing.',
      matchPackageNames: ['posthog/posthog'],
      matchFileNames: ['my-apps/development/posthog/**'],
      enabled: false,
    },
    {
      description: 'PostHog data layer: disable auto-updates (versions must match PostHog docker-compose.base.yml)',
      matchPackageNames: [
        'postgres',
        'valkey/valkey',
        'redis',
        'clickhouse/clickhouse-server',
        'docker.redpanda.com/redpandadata/redpanda',
      ],
      matchFileNames: ['my-apps/development/posthog/**'],
      enabled: false,
    },
    {
      description: 'Pin project-nomad MySQL to 8.x (AdonisJS/Lucid not tested with MySQL 9)',
      matchPackageNames: ['mysql'],
      matchFileNames: ['my-apps/home/project-nomad/**'],
      allowedVersions: '<9.0.0',
    },
    {
      description: 'temporal-worker-controller: chart and IMAGE share the same OCI repo (docker.io/temporalio/temporal-worker-controller). Image tags look like v1.5.x; chart tags look like 0.24.x. Constrain to chart-style (no `v` prefix, two-part minor) so Renovate cannot bump us onto an image tag (it did exactly that in #1224, breaking CI repo-wide for ~9 days because `helm pull` rejects a plain image OCI artifact with "manifest does not contain minimum number of descriptors").',
      matchPackageNames: [
        'docker.io/temporalio/temporal-worker-controller',
        'docker.io/temporalio/temporal-worker-controller-crds',
      ],
      allowedVersions: '/^\\d+\\.\\d+\\.\\d+$/',
    },
    {
      // Renovate forbids combining matchUpdateTypes with allowedVersions or
      // versioning in the same packageRule (they're orthogonal scoping
      // axes). Split into two rules: one defines the candidate-version
      // stream for the package; the other says how to behave on minor/patch
      // updates within that stream.
      description: 'radar-ng images (in-cluster registry): only consider semver vX.Y.Z tags. Build flow lives in radar-ng/.gitea/workflows/build-*.yml — every push to master auto-bumps patch (next semver computed by reading the registry), pushes the image, Renovate sees it within an hour and PRs the bump here. Excludes :latest, :git-<sha>, and :buildcache from candidate set so Renovate never proposes downgrading a pinned :v1.0.x to a floating tag.',
      matchDatasources: ['docker'],
      matchPackageNames: [
        'registry.vanillax.me/radar-ng-tile-server',
        'registry.vanillax.me/radar-ng-ingest-mrms',
        'registry.vanillax.me/radar-ng-ingest-hrrr',
        'registry.vanillax.me/radar-ng-ingest-lightning',
        'registry.vanillax.me/radar-ng-ingest-tropical',
        'registry.vanillax.me/radar-ng-nowcast',
        'registry.vanillax.me/radar-ng-basemap',
      ],
      versioning: 'semver-coerced',
      allowedVersions: '/^v\\d+\\.\\d+\\.\\d+$/',
    },
    {
      description: 'radar-ng images: auto-merge minor+patch within the v\\d+.\\d+.\\d+ stream constrained above.',
      matchDatasources: ['docker'],
      matchPackageNames: [
        'registry.vanillax.me/radar-ng-tile-server',
        'registry.vanillax.me/radar-ng-ingest-mrms',
        'registry.vanillax.me/radar-ng-ingest-hrrr',
        'registry.vanillax.me/radar-ng-ingest-lightning',
        'registry.vanillax.me/radar-ng-ingest-tropical',
        'registry.vanillax.me/radar-ng-nowcast',
        'registry.vanillax.me/radar-ng-basemap',
      ],
      matchUpdateTypes: ['patch', 'minor'],
      automerge: true,
      automergeType: 'branch',
    },
    {
      description: 'news-reader + news-reader-temporal-worker images (in-cluster registry): only consider semver vX.Y.Z tags. Build flows live in news-reader/.gitea/workflows/build.yml and news-reader-temporal-worker/.gitea/workflows/build.yml (both Gitea Actions, both run on the in-cluster act-runner so they can reach registry.vanillax.me — GitHub-hosted runners cannot). Every push to main auto-bumps patch (next semver computed by reading the registry), pushes the image, Renovate sees it within an hour and PRs the bump here. Excludes :latest and :buildcache from the candidate set.',
      matchDatasources: ['docker'],
      matchPackageNames: [
        'registry.vanillax.me/news-reader',
        'registry.vanillax.me/news-reader-temporal-worker',
      ],
      versioning: 'semver-coerced',
      allowedVersions: '/^v\\d+\\.\\d+\\.\\d+$/',
    },
    {
      description: 'news-reader + news-reader-temporal-worker images: auto-merge minor+patch within the v\\d+.\\d+.\\d+ stream.',
      matchDatasources: ['docker'],
      matchPackageNames: [
        'registry.vanillax.me/news-reader',
        'registry.vanillax.me/news-reader-temporal-worker',
      ],
      matchUpdateTypes: ['patch', 'minor'],
      automerge: true,
      automergeType: 'branch',
    },
  ],
  ignorePaths: [
    '**/charts/**',
  ],
  customManagers: [
    {
      description: 'Omni cluster template - Talos version',
      customType: 'regex',
      managerFilePatterns: [
        '/^omni/cluster-template/cluster-template\\.yaml$/',
      ],
      matchStrings: [
        'talos:\\s*\\n\\s+version:\\s*(?<currentValue>v[0-9.]+)',
      ],
      depNameTemplate: 'ghcr.io/siderolabs/installer',
      datasourceTemplate: 'docker',
    },
    {
      description: 'Omni cluster template - Kubernetes version',
      customType: 'regex',
      managerFilePatterns: [
        '/^omni/cluster-template/cluster-template\\.yaml$/',
      ],
      matchStrings: [
        'kubernetes:\\s*\\n\\s+version:\\s*(?<currentValue>v[0-9.]+)',
      ],
      depNameTemplate: 'ghcr.io/siderolabs/kubelet',
      datasourceTemplate: 'docker',
    },
    {
      description: 'K8sGPT operator CR image reference',
      customType: 'regex',
      managerFilePatterns: [
        '/^monitoring/k8sgpt/.+\\.yaml$/',
      ],
      matchStrings: [
        'repository:\\s*(?<depName>[^\\s]+)\\n\\s+version:\\s*"?(?<currentValue>[\\w.]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?',
      ],
      datasourceTemplate: 'docker',
    },
  ],
}
